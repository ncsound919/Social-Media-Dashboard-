# Social Ops Studio - Environment Configuration
# Copy this file to .env.local and fill in the values

# App Environment (dev, staging, production)
NEXT_PUBLIC_APP_ENV=dev

# API Base URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api

# ─── NextAuth.js ─────────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# ─── Authelia OIDC ───────────────────────────────────────────────────────────
AUTHELIA_URL=https://auth.your-domain.example.com
AUTHELIA_CLIENT_ID=social-ops-studio
AUTHELIA_CLIENT_SECRET=

# ─── OpenCode LLM ────────────────────────────────────────────────────────────
OPENCODE_API_URL=http://localhost:4096
OPENCODE_MODEL=auto

# ─── Redis / Celery ──────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Platform OAuth Credentials ──────────────────────────────────────────────

# LinkedIn OAuth 2.0 PKCE
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Twitter / X OAuth 2.0 PKCE
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# TikTok OAuth 2.0
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=

# Instagram / Meta Graph API
META_APP_ID=
META_APP_SECRET=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# YouTube (Google) OAuth 2.0
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Facebook Pages (Meta Graph API)
FACEBOOK_PAGE_ID=
FACEBOOK_AD_ACCOUNT_ID=

# Pinterest OAuth 2.0
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=

# Bluesky (AT Protocol — uses app password, no OAuth)
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=

# ─── Platform Access Tokens (set after OAuth flow) ───────────────────────────
LINKEDIN_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN=
TIKTOK_ACCESS_TOKEN=
INSTAGRAM_ACCESS_TOKEN=
YOUTUBE_ACCESS_TOKEN=
YOUTUBE_REFRESH_TOKEN=
FACEBOOK_ACCESS_TOKEN=
PINTEREST_ACCESS_TOKEN=

# ─── Facebook Pages (legacy env var names kept for backward compat) ───────────
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# ─── Instagram Business (legacy env var names kept for backward compat) ───────
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=

# ─── YouTube (legacy env var names kept for backward compat) ─────────────────
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# ─── Pinterest (legacy env var names kept for backward compat) ───────────────
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=

# ─── Optional: Analytics and monitoring ──────────────────────────────────────
# NEXT_PUBLIC_ANALYTICS_ID=

# ─── Optional: Local AI (Ollama) ─────────────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434

