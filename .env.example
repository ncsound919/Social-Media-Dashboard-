# ─────────────────────────────────────────────────────────────────────────────
# Social Media Dashboard — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# Redis connection URL (used by Celery broker and result backend)
REDIS_URL=redis://localhost:6379/0

# ─── AI Device ────────────────────────────────────────────────────────────────
# Set to "cuda" to enable GPU acceleration (requires NVIDIA GPU + CUDA).
# Defaults to "cpu" — no GPU needed for a basic deployment.
AI_DEVICE=cpu

# AI backend for text generation: "transformers" (local) or "ollama"
AI_BACKEND=transformers

# ─── Model overrides ──────────────────────────────────────────────────────────
# Qwen text model (lighter 3B is default; use 7B for higher quality on GPU)
# QWEN_MODEL=Qwen/Qwen2.5-3B-Instruct

# Stable Diffusion model (v1.5 is default; use SDXL on GPU for better quality)
# SD_MODEL=runwayml/stable-diffusion-v1-5

# Video generation model
# VIDEO_MODEL=damo-vilab/text-to-video-ms-1.7b

# Coqui TTS model
# COQUI_MODEL=tts_models/en/ljspeech/tacotron2-DDC

# MusicGen model (small is default; facebook/musicgen-medium for better quality)
# MUSICGEN_MODEL=facebook/musicgen-small

# Bark model size: "small" (faster on CPU) or "large" (better quality on GPU)
# BARK_MODEL_SIZE=small

# Ollama settings (only needed when AI_BACKEND=ollama)
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:7b

# OpenVoice checkpoint directory (required for voice cloning)
# OPENVOICE_CKPT=checkpoints/converter

# ─── CORS / Frontend ─────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins for the FastAPI CORS policy.
# Leave empty to allow all origins (no credentials).
# FRONTEND_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Platform OAuth Tokens ───────────────────────────────────────────────────
# TWITTER_ACCESS_TOKEN=
# LINKEDIN_ACCESS_TOKEN=
# INSTAGRAM_ACCESS_TOKEN=
# TIKTOK_ACCESS_TOKEN=
# YOUTUBE_ACCESS_TOKEN=
# FACEBOOK_ACCESS_TOKEN=
# PINTEREST_ACCESS_TOKEN=

# ─── OpenCode AI API ─────────────────────────────────────────────────────────
# URL and optional API key for the OpenCode LLM backend.
# OPENCODE_API_URL=http://localhost:4000
# OPENCODE_API_KEY=
# OPENCODE_MODEL=auto
